generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id        Int      @id @default(autoincrement())
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]
  toolCalls ToolCall[]
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant"
  content        String
  createdAt      DateTime     @default(now())
}

model ToolCall {
  id             Int           @id @default(autoincrement())
  conversationId Int?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  toolName       String
  inputJson      Json
  resultJson     Json
  durationMs     Int
  createdAt      DateTime      @default(now())
}

model ApiCache {
  id           String   @id @default(uuid())
  provider     String   // "aerodatabox"
  cacheKey     String   @unique
  responseJson Json
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([provider])
  @@index([expiresAt])
}

model AirportScoreSnapshot {
  id              String   @id @default(uuid())
  iata            String
  scoreJson       Json
  sourcesJson     Json
  uncertaintyJson Json
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([iata])
  @@index([expiresAt])
}
